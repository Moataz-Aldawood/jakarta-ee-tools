{
  "name": "jakarta-ee-tools",
  "author": "Moataz Aldawood and his friend Google Gemini ;)",
  "publisher": "moataz-aldawood",
  "displayName": "Jakarta Faces Tools",
  "description": "Advanced Jakarta Faces (JSF) tools: deep nested Java EL resolution, custom composite component intelligence, real-time diagnostics, and hover documentation. GitHub: https://github.com/Moataz-Aldawood/jakarta-faces-tools",
  "version": "1.8.0",
  "icon": "logo.png",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moataz-Aldawood/jakarta-faces-tools"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "Jakarta EE",
    "JSF",
    "Java",
    "Java EE",
    "Coding Utilities",
    "PrimeFaces",
    "OmniFaces",
    "BootsFaces",
    "Unknown Tag Detection",
    "Unknown Attribute Detection"
  ],
  "activationEvents": [
    "onLanguage:jsf",
    "onLanguage:html",
    "onLanguage:xml"
  ],
  "contributes": {
    "configuration": {
      "title": "Jakarta Faces Tools",
      "properties": {
        "jakartaFaces.elHighlight.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable highlighting for EL Expressions (#{...})."
        },
        "jakartaFaces.elHighlight.backgroundColor": {
          "type": "string",
          "default": "rgba(100, 150, 255, 0.15)",
          "description": "Background color for EL Expressions. Supports CSS colors (e.g. rgba, hex)."
        },
        "jakartaFaces.elHighlight.color": {
          "type": "string",
          "default": "",
          "description": "Text color for EL Expressions (leave empty to use theme default)."
        },
        "jakartaFaces.elHighlight.border": {
          "type": "string",
          "default": "1px solid rgba(100, 150, 255, 0.3)",
          "description": "Border for EL Expressions."
        },
        "jakartaFaces.elHighlight.borderRadius": {
          "type": "string",
          "default": "3px",
          "description": "Border radius for EL Expressions."
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  }
}
