{
  "name": "jakarta-faces-tools",
  "author": "Moataz Aldawood and his friend Google Gemini ;)",
  "publisher": "moataz-aldawood",
  "displayName": "Jakarta Faces Tools",
  "description": "Advanced Jakarta Faces (JSF) tools: deep nested Java EL resolution, custom composite component intelligence, real-time diagnostics, and hover documentation. GitHub: https://github.com/Moataz-Aldawood/jakarta-faces-tools",
  "version": "1.6.1",
  "icon": "logo.png",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moataz-Aldawood/jakarta-faces-tools"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "Jakarta EE",
    "JSF",
    "Java",
    "Java EE",
    "Coding Utilities"
  ],
  "activationEvents": [
    "onLanguage:jsf",
    "onLanguage:html",
    "onLanguage:xml"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  }
}
